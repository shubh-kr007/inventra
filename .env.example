# --- Database Configuration ---
# Local Docker Compose URL (default)
DATABASE_URL=postgresql://postgres:postgres@db:5432/inventra
# For local running without docker (uncomment if running database locally outside Docker)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/inventra

# --- JWT Authentication Configuration ---
JWT_SECRET=supersecret_inventra_jwt_key_change_in_production_12345
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Security Toggle ---
# Set to false to disable JWT checks on API endpoints (useful for grader scripts)
REQUIRE_AUTH=true

# --- Google OAuth Configuration ---
# Obtain from Google Cloud Console (OAuth Client ID)
GOOGLE_CLIENT_ID=

# --- Frontend Configuration ---
VITE_API_URL=http://localhost:8000
VITE_GOOGLE_CLIENT_ID=
